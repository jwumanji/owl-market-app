{
  "name": "moon-market",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run owl-lens:check-types && next build",
    "start": "next start",
    "lint": "next lint",
    "test:multitcg": "node --test tests/multitcg-foundation.test.ts && node scripts/sync-schedule-manifest.mjs",
    "audit:multitcg-preflight": "node scripts/audit-multitcg-preflight.mjs",
    "audit:multitcg-reconcile": "node scripts/audit-multitcg-reconciliation.mjs",
    "golden:cards": "node scripts/card-api-golden.mjs",
    "golden:gate4-expected-diffs": "node scripts/capture-gate4-expected-diffs.mjs",
    "audit:game-boundaries": "node scripts/audit-game-boundaries.mjs",
    "audit:public-performance": "node scripts/audit-public-performance.mjs",
    "audit:set-membership": "node scripts/audit-set-membership.mjs",
    "audit:riftbound-pricing": "node scripts/audit-riftbound-pricing-readiness.mjs",
    "audit:riftbound-justtcg": "node scripts/audit-riftbound-justtcg.mjs",
    "audit:sync-schedule": "node scripts/sync-schedule-manifest.mjs",
    "sync-schedule:generate": "node scripts/sync-schedule-manifest.mjs --write",
    "riftbound:audit": "node scripts/riftbound-audit.mjs",
    "test:riftbound": "node --test tests/riftbound-justtcg.test.ts tests/riftbound-catalog.test.ts tests/card-image-variants.test.ts",
    "owl-lens:sync-contract": "node scripts/owl-lens-sync.mjs",
    "owl-lens:generate-types": "openapi-typescript contracts/owl-lens.openapi.yaml -o src/lib/owl-lens/openapi.generated.ts",
    "owl-lens:check-types": "node scripts/owl-lens-check.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "chart.js": "^4.5.1",
    "html-to-image": "^1.11.13",
    "justtcg-js": "^0.1.22",
    "next": "^15.5.20",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "react-dropzone": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^8",
    "eslint-config-next": "^15.5.20",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
