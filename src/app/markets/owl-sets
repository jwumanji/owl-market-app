<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sets - OWL Market</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=IBM+Plex+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
:root{--void:#03050D;--surface:#0A1020;--surf2:#0E1628;--surf3:#121D32;--border:rgba(255,255,255,0.055);--border2:rgba(255,255,255,0.10);--owl:#E8A020;--owl2:#F5BE50;--owl-d:rgba(232,160,32,0.12);--green:#00D68F;--green-d:rgba(0,214,143,0.10);--red:#FF4560;--text:#E4EAF6;--text2:#7A88A8;--text3:#3D4D6A;--mono:'IBM Plex Mono',monospace;--display:'Inter',sans-serif;--sans:'Inter',sans-serif;--nav-h:54px;--bar-h:28px;--top:82px;}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--void);color:var(--text);font-family:var(--sans);font-size:14px;line-height:1.6;overflow-x:hidden;}
body::after{content:'';position:fixed;inset:0;z-index:0;background-image:linear-gradient(rgba(232,160,32,0.016) 1px,transparent 1px),linear-gradient(90deg,rgba(232,160,32,0.016) 1px,transparent 1px);background-size:56px 56px;pointer-events:none;}
.z1{position:relative;z-index:1;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.15}}
@keyframes ticker{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
nav{position:fixed;top:0;left:0;right:0;z-index:500;display:flex;flex-direction:column;background:rgba(3,5,13,0.94);backdrop-filter:blur(28px);border-bottom:1px solid var(--border);}
.nav-row{height:var(--nav-h);padding:0 22px;display:flex;align-items:center;justify-content:space-between;}
.logo{display:flex;align-items:center;gap:9px;text-decoration:none;}
.logo-owl{width:32px;height:32px;border-radius:7px;background:var(--owl);display:flex;align-items:center;justify-content:center;font-size:17px;box-shadow:0 0 16px rgba(232,160,32,0.4);}
.logo-name{font-family:var(--display);font-size:18px;font-weight:800;color:var(--text);}
.logo-name span{color:var(--owl);}
.nav-mid{display:flex;align-items:center;gap:2px;}
.nav-link{font-family:var(--mono);font-size:10px;color:var(--text2);text-decoration:none;padding:5px 12px;border-radius:5px;letter-spacing:0.03em;transition:all .14s;}
.nav-link:hover{color:var(--text);background:var(--surf2);}
.nav-link.active{color:var(--owl);background:var(--owl-d);border:1px solid rgba(232,160,32,0.2);}
.nav-right{display:flex;align-items:center;gap:10px;}
.live-badge{font-family:var(--mono);font-size:11px;color:var(--green);background:var(--green-d);border:1px solid rgba(0,214,143,0.22);padding:4px 10px;border-radius:3px;letter-spacing:0.03em;display:flex;align-items:center;gap:5px;}
.live-dot{width:5px;height:5px;background:var(--green);border-radius:50%;animation:blink 1.5s infinite;}
.btn-login{font-family:var(--mono);font-size:10px;font-weight:500;color:var(--text2);background:transparent;border:1px solid var(--border2);padding:7px 16px;border-radius:5px;cursor:pointer;letter-spacing:0.03em;text-decoration:none;transition:all .14s;}
.btn-login:hover{color:var(--text);background:var(--surf2);}
.btn-signup{font-family:var(--mono);font-size:10px;font-weight:500;color:var(--void);background:var(--owl);border:none;padding:7px 18px;border-radius:5px;cursor:pointer;letter-spacing:0.03em;}
.ticker-bar{width:100%;height:var(--bar-h);background:var(--surf2);border-top:1px solid var(--border);overflow:hidden;display:flex;align-items:center;flex-shrink:0;}
.ticker-track{display:flex;animation:ticker 55s linear infinite;width:max-content;}
.ti{display:flex;align-items:center;gap:8px;padding:0 20px;border-right:1px solid var(--border);white-space:nowrap;height:var(--bar-h);font-family:var(--mono);font-size:10px;}
.ti-name{color:var(--text2);}.ti-price{color:var(--text);font-weight:500;}.ti-up{color:var(--green);}.ti-dn{color:var(--red);}
.page{padding-top:calc(var(--top) + 24px);max-width:1280px;margin:0 auto;padding-left:24px;padding-right:24px;padding-bottom:80px;}
.breadcrumb{display:flex;align-items:center;gap:6px;font-family:var(--mono);font-size:11px;color:var(--text2);margin-bottom:20px;}
.breadcrumb a{color:var(--text2);text-decoration:none;}.bsep{color:var(--text3);}
.ph-eyebrow{font-family:var(--mono);font-size:11px;color:var(--owl);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:8px;}
.ph-title{font-family:var(--display);font-size:36px;font-weight:800;letter-spacing:-0.5px;color:var(--text);margin-bottom:6px;line-height:1;}
.ph-title span{color:var(--owl);}
.ph-sub{font-size:13px;color:var(--text2);font-weight:300;margin-bottom:24px;}
.set-index-row{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:10px;animation:fadeUp .4s .05s ease both;}
.sic{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:12px 12px 10px;cursor:pointer;transition:all .18s;position:relative;overflow:hidden;}
.sic::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--sic-color,#E8A020),transparent);opacity:0;transition:opacity .18s;}
.sic:hover{border-color:var(--border2);transform:translateY(-1px);}
.sic:hover::before,.sic.active::before{opacity:1;}
.sic-header{display:flex;align-items:flex-start;justify-content:space-between;gap:6px;margin-bottom:4px;}
.sic-code{font-family:var(--mono);font-size:11px;font-weight:700;color:var(--text);}
.sic-badge{font-family:var(--mono);font-size:9px;padding:2px 6px;border-radius:3px;font-weight:600;letter-spacing:0.05em;display:inline-block;flex-shrink:0;}
.sic-name{font-size:10px;color:var(--text2);margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sic-price{font-family:var(--display);font-size:15px;font-weight:800;color:var(--text);letter-spacing:-0.3px;line-height:1;margin-bottom:2px;}
.sic-chg{font-family:var(--mono);font-size:14px;font-weight:700;margin-bottom:5px;letter-spacing:-0.3px;}
.sic-spark{height:28px;width:100%;display:block;}
.set-pill-strip{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:22px;animation:fadeUp .4s .08s ease both;}
.set-pill{display:flex;align-items:center;gap:8px;background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:6px 12px 6px 10px;cursor:pointer;transition:all .16s;}
.set-pill:hover{border-color:var(--border2);transform:translateY(-1px);background:var(--surf2);}
.set-pill.active{border-color:var(--owl);background:var(--owl-d);}
.set-pill-code{font-family:var(--mono);font-size:12px;font-weight:700;color:var(--text);}
.set-pill-name{font-size:11px;color:var(--text2);}
.set-pill-val{font-family:var(--mono);font-size:11px;font-weight:600;color:var(--text);}
.set-pill-chg{font-family:var(--mono);font-size:11px;font-weight:700;}
.detail-section{display:grid;grid-template-columns:320px 1fr;gap:20px;margin-bottom:28px;animation:fadeUp .4s .1s ease both;}
.set-detail-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;}
.sdc-box-art{width:100%;height:150px;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;border-bottom:1px solid var(--border);}
.sdc-box-img{width:78px;height:108px;border-radius:6px;border:2px solid rgba(255,255,255,0.14);display:flex;align-items:center;justify-content:center;font-size:38px;position:relative;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,0.6);z-index:1;}
.sdc-box-label{font-family:var(--mono);font-size:10px;color:rgba(255,255,255,0.35);letter-spacing:0.1em;text-transform:uppercase;margin-top:6px;z-index:1;}
.sdc-header{padding:16px 18px;border-bottom:1px solid var(--border);position:relative;overflow:hidden;}
.sdc-code{font-family:var(--mono);font-size:11px;padding:3px 10px;border-radius:3px;font-weight:600;letter-spacing:0.07em;display:inline-block;margin-bottom:10px;}
.sdc-name{font-family:var(--display);font-size:22px;font-weight:800;color:var(--text);margin-bottom:4px;letter-spacing:-0.2px;}
.sdc-desc{font-size:13px;color:var(--text2);line-height:1.6;font-weight:300;}
.sdc-row{display:flex;align-items:center;justify-content:space-between;padding:10px 18px;border-bottom:1px solid var(--border);}
.sdc-row:last-child{border-bottom:none;}
.sdc-key{font-family:var(--mono);font-size:11px;color:var(--text2);}
.sdc-val{font-family:var(--mono);font-size:11px;color:var(--text);font-weight:500;text-align:right;}
.index-chart-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;}
.icc-header{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--border);}
.icc-title{font-family:var(--display);font-size:16px;font-weight:700;color:var(--text);}
.icc-price{font-family:var(--display);font-size:28px;font-weight:800;color:var(--text);letter-spacing:-0.5px;line-height:1;margin-top:4px;}
.icc-sub{font-family:var(--mono);font-size:11px;color:var(--text2);margin-top:3px;}
.icc-right{display:flex;gap:2px;}
.icc-time{font-family:var(--mono);font-size:10px;color:var(--text2);padding:4px 9px;border-radius:3px;cursor:pointer;border:none;background:transparent;transition:all .14s;}
.icc-time:hover{color:var(--text);background:var(--surf2);}
.icc-time.on{background:var(--owl-d);color:var(--owl);border:1px solid rgba(232,160,32,0.25);}
.perf-strip{display:grid;grid-template-columns:repeat(6,1fr);gap:1px;border-top:1px solid var(--border);}
.perf-cell{background:var(--surf2);padding:12px;text-align:center;}
.perf-period{font-family:var(--mono);font-size:10px;color:var(--text2);letter-spacing:0.06em;margin-bottom:4px;text-transform:uppercase;}
.perf-val{font-family:var(--mono);font-size:14px;font-weight:700;}
.top-cards-section{margin-bottom:28px;animation:fadeUp .4s .15s ease both;}
.section-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:10px;}
.section-title{font-family:var(--display);font-size:20px;font-weight:700;color:var(--text);}
.section-title span{color:var(--owl);}
.section-sub{font-family:var(--mono);font-size:11px;color:var(--text2);margin-top:2px;}
.section-action{font-family:var(--mono);font-size:11px;color:var(--owl);background:var(--owl-d);border:1px solid rgba(232,160,32,0.25);padding:3px 10px;border-radius:3px;text-decoration:none;flex-shrink:0;}
.set-tabs{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px;}
.stab{font-family:var(--mono);font-size:11px;padding:5px 12px;border-radius:4px;border:1px solid var(--border);color:var(--text);cursor:pointer;letter-spacing:0.02em;transition:all .14s;background:transparent;font-weight:600;}
.stab:hover{border-color:var(--border2);background:var(--surf2);}
.cards-table-wrap{background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;}
.cards-table{width:100%;border-collapse:collapse;table-layout:fixed;}
.cards-table col.c0{width:44px;}.cards-table col.c1{width:240px;}.cards-table col.c2{width:100px;}.cards-table col.c3{width:95px;}.cards-table col.c4{width:95px;}.cards-table col.c5{width:68px;}.cards-table col.c6{width:68px;}.cards-table col.c7{width:68px;}.cards-table col.c8{width:110px;}
.cards-table th{font-family:var(--mono);font-size:11px;color:var(--text2);letter-spacing:0.06em;text-transform:uppercase;padding:10px 12px;border-bottom:1px solid var(--border);text-align:left;font-weight:500;background:var(--surf2);white-space:nowrap;}
.cards-table th.r{text-align:right;}
.cards-table td{padding:10px 12px;border-bottom:1px solid var(--border);vertical-align:middle;overflow:hidden;}
.cards-table tr:last-child td{border-bottom:none;}
.cards-table tbody tr{cursor:pointer;transition:background .1s;}
.cards-table tbody tr:hover td{background:rgba(255,255,255,0.022);}
.rank-n{font-family:var(--mono);font-size:11px;color:var(--text2);text-align:center;}
.card-cell{display:flex;align-items:center;gap:10px;}
.card-art{width:28px;height:38px;border-radius:3px;background:var(--surf3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.card-name{font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.card-set-tag{font-family:var(--mono);font-size:10px;color:var(--text2);font-weight:600;}
.rb{font-family:var(--mono);font-size:9px;padding:2px 6px;border-radius:2px;font-weight:600;letter-spacing:0.03em;white-space:nowrap;display:inline-block;}
.rb-mr{background:rgba(232,160,32,0.18);color:#E8A020;border:1px solid rgba(232,160,32,0.3);}
.rb-sp{background:rgba(155,114,255,0.18);color:#B89AFF;border:1px solid rgba(155,114,255,0.3);}
.rb-sec{background:rgba(255,69,96,0.18);color:#FF8FA0;border:1px solid rgba(255,69,96,0.3);}
.rb-tr{background:rgba(234,179,8,0.18);color:#FDE047;border:1px solid rgba(234,179,8,0.3);}
.rb-aa{background:rgba(79,142,247,0.18);color:#7FB0FA;border:1px solid rgba(79,142,247,0.3);}
.rb-sr{background:rgba(0,214,143,0.15);color:#00D68F;border:1px solid rgba(0,214,143,0.28);}
.rb-gmr{background:rgba(245,190,80,0.25);color:#F5BE50;border:1px solid rgba(245,190,80,0.5);}
.price-r{text-align:right;font-family:var(--mono);font-size:12px;font-weight:600;color:var(--text);}
.chg-r{text-align:right;font-family:var(--mono);font-size:12px;font-weight:600;}
.up{color:var(--green);}.dn{color:var(--red);}
.comparison-section{margin-bottom:28px;animation:fadeUp .4s .2s ease both;}
.comp-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
.comp-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px;transition:all .18s;cursor:pointer;}
.comp-card:hover{border-color:var(--border2);transform:translateY(-1px);}
.comp-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:4px;gap:6px;}
.comp-code-row{display:flex;align-items:center;gap:7px;flex:1;min-width:0;}
.comp-code{font-family:var(--mono);font-size:11px;font-weight:700;color:var(--text);}
.comp-badge{font-family:var(--mono);font-size:9px;padding:2px 6px;border-radius:3px;letter-spacing:0.05em;flex-shrink:0;}
.comp-chg{font-family:var(--mono);font-size:18px;font-weight:700;letter-spacing:-0.3px;flex-shrink:0;}
.comp-name{font-size:13px;color:var(--text2);margin-bottom:6px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.comp-val{font-family:var(--display);font-size:24px;font-weight:800;color:var(--text);letter-spacing:-0.3px;margin-bottom:2px;line-height:1;}
.comp-meta{font-family:var(--mono);font-size:11px;color:var(--text2);margin-bottom:10px;}
.comp-spark{width:100%;height:52px;display:block;margin-bottom:10px;}
.comp-footer{display:flex;justify-content:space-between;padding-top:10px;border-top:1px solid var(--border);}
.comp-stat{font-family:var(--mono);font-size:11px;color:var(--text2);}
.comp-stat-val{color:var(--text);}
.pull-rates-section{margin-bottom:28px;animation:fadeUp .4s .25s ease both;}
.pr-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
.pr-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px;}
.pr-badge{font-family:var(--mono);font-size:11px;padding:2px 8px;border-radius:3px;display:inline-block;margin-bottom:10px;letter-spacing:0.06em;font-weight:600;}
.pr-name{font-family:var(--display);font-size:14px;font-weight:700;color:var(--text);margin-bottom:10px;}
.pr-rate-row{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.pr-rate-label{font-family:var(--mono);font-size:11px;color:var(--text2);width:90px;flex-shrink:0;}
.pr-rate-track{flex:1;height:5px;background:var(--surf3);border-radius:3px;overflow:hidden;}
.pr-rate-fill{height:100%;border-radius:3px;}
.pr-rate-num{font-family:var(--mono);font-size:11px;color:var(--text2);width:52px;text-align:right;flex-shrink:0;}
.pr-note{font-family:var(--mono);font-size:11px;color:var(--text2);line-height:1.5;margin-top:10px;padding-top:10px;border-top:1px solid var(--border);}

</style>
</head>
<body>
<nav>
  <div class="nav-row">
    <a href="#" class="logo"><div class="logo-owl">🦉</div><span class="logo-name">OWL<span> Market</span></span></a>
    <div class="nav-mid">
      <a href="#" class="nav-link">HOME</a>
      <a href="owl-market.html" class="nav-link">MARKETS</a>
      <a href="owl-rarities.html" class="nav-link">RARITIES</a>
      <a href="#" class="nav-link active">SETS</a>
      <a href="owl-characters.html" class="nav-link">CHARACTERS</a>
      <a href="#" class="nav-link">PORTFOLIO</a>
    </div>
    <div class="nav-right">
      <div class="live-badge"><span class="live-dot"></span>LIVE</div>
      <a href="#" class="btn-login">Login</a>
      <button class="btn-signup">Sign Up</button>
    </div>
  </div>
  <div class="ticker-bar"><div class="ticker-track" id="ticker"></div></div>
</nav>
<div class="page z1">
  <div class="breadcrumb"><a href="#">OWL Market</a><span class="bsep"> › </span><span style="color:var(--text)">Sets</span></div>
  <div class="ph-eyebrow">One Piece TCG</div>
  <div class="ph-title">Set <span>Index</span></div>
  <div class="ph-sub">21 sets tracked · Top 5 ranked by 7D momentum · Updates with live data</div>
  <div class="set-index-row" id="set-index-row"></div>
  <div class="set-pill-strip" id="set-pill-strip"></div>
  <div class="detail-section">
    <div class="set-detail-card" id="set-detail-card"></div>
    <div class="index-chart-card">
      <div class="icc-header">
        <div>
          <div class="icc-title" id="chart-title">OP01 Romance Dawn Index</div>
          <div class="icc-price" id="chart-price">$4,840</div>
          <div class="icc-sub" id="chart-sub">Total card value · 115 cards tracked</div>
        </div>
        <div class="icc-right">
          <button class="icc-time on" onclick="setChartTime(this,'7d')">7D</button>
          <button class="icc-time" onclick="setChartTime(this,'1m')">1M</button>
          <button class="icc-time" onclick="setChartTime(this,'3m')">3M</button>
          <button class="icc-time" onclick="setChartTime(this,'1y')">1Y</button>
          <button class="icc-time" onclick="setChartTime(this,'max')">Max</button>
        </div>
      </div>
      <div><canvas id="idx-chart" style="height:240px"></canvas></div>
      <div class="perf-strip" id="perf-strip"></div>
    </div>
  </div>
  <div class="top-cards-section">
    <div class="section-header">
      <div><div class="section-title">Top Cards — <span id="top-cards-title">OP01</span></div><div class="section-sub" id="top-cards-sub">Ranked by current market value</div></div>
      <a href="owl-market.html" class="section-action">View all in markets →</a>
    </div>
    <div style="display:flex;justify-content:flex-end;align-items:center;gap:10px;margin-bottom:10px">
      <div style="display:flex;align-items:center;gap:2px;background:var(--surf2);border:1px solid var(--border2);border-radius:6px;padding:3px">
        <button class="icc-time" onclick="setTopTime(this)">24H</button>
        <button class="icc-time" onclick="setTopTime(this)">7D</button>
        <button class="icc-time on" onclick="setTopTime(this)">30D</button>
        <button class="icc-time" onclick="setTopTime(this)">ALL</button>
      </div>
      <select style="font-family:var(--mono);font-size:11px;color:var(--text2);background:var(--surface);border:1px solid var(--border);padding:6px 10px;border-radius:5px;outline:none;cursor:pointer"><option>Sort: Market Value</option><option>Sort: 7D Change</option></select>
    </div>
    <div class="set-tabs" id="set-tabs"></div>
    <div class="cards-table-wrap">
      <table class="cards-table">
        <colgroup><col class="c0"><col class="c1"><col class="c2"><col class="c3"><col class="c4"><col class="c5"><col class="c6"><col class="c7"><col class="c8"></colgroup>
        <thead><tr><th>#</th><th>Card</th><th>Rarity</th><th class="r">Avg Price</th><th class="r">TCGPlayer</th><th class="r">24H</th><th class="r">7D</th><th class="r">30D</th><th class="r">Last 7 Days</th></tr></thead>
        <tbody id="top-cards-tbody"></tbody>
      </table>
    </div>
  </div>

