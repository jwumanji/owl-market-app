async function hydrateLiveData() {
  try {
    const res = await fetch('/api/sets');
    if (!res.ok) return;
    const dbSets = await res.json();

    const dbMap = Object.fromEntries(dbSets.map(s => [s.slug, s]));

    SETS.forEach(s => {
      const db = dbMap[s.slug];
      if (!db) return;

      // Dynamic fields from DB
      s.cards = db.cards;

      if (db.topCards.length > 0) {
        s.topCards = s.topCards.map((tc, i) => {
          const live = db.topCards[i];
          if (!live) return tc;
          return {
            ...tc,                          // keep emoji (e), rb, and static fields
            n:   live.n  || tc.n,
            rl:  live.rl || tc.rl,
            tcg: live.tcg || tc.tcg,
            avg: live.avg || tc.avg,
            d1:  live.d1  ?? tc.d1,
            d7:  live.d7  ?? tc.d7,
            d30: live.d30 ?? tc.d30,
            sp:  live.sp.length >= 2 ? live.sp : tc.sp,
          };
        });
      }
    });

    // Re-render with live data
    selectSet(activeSet);
    buildComparison();

  } catch (e) {
    console.warn('[OWL] Live data unavailable, using static fallback', e);
  }
}

