function buildPullRates(s) {
  document.getElementById('pr-title').innerHTML = `Pull Rates <span>— ${s.code} ${s.name}</span>`;
  const rates = PULL_RATES[s.slug] || DEFAULT_PULL_RATES;
  const maxPerPack = Math.max(...rates.map(r=>r.perPack));
  document.getElementById('pr-grid').innerHTML = rates.map(r => {
    const packPct  = (r.perPack / maxPerPack * 100).toFixed(0);
    const boxPct   = Math.min(r.perBox / 24 * 100, 100).toFixed(0);
    const casePct  = Math.min(r.perCase / 144 * 100, 100).toFixed(0);
    return `<div class="pr-card">
      <div class="pr-badge" style="background:${r.colorD};color:${r.color};border:1px solid ${r.colorBd}">${r.code}</div>
      <div class="pr-name">${r.name}</div>
      <div class="pr-rate-row">
        <span class="pr-rate-label">Per pack</span>
        <div class="pr-rate-track"><div class="pr-rate-fill" style="width:${packPct}%;background:${r.color}"></div></div>
        <span class="pr-rate-num">${r.perPack.toFixed(1)}%</span>
      </div>
      <div class="pr-rate-row">
        <span class="pr-rate-label">Per box</span>
        <div class="pr-rate-track"><div class="pr-rate-fill" style="width:${boxPct}%;background:${r.color}"></div></div>
        <span class="pr-rate-num">~${r.perBox}</span>
      </div>
      <div class="pr-rate-row">
        <span class="pr-rate-label">Per case</span>
        <div class="pr-rate-track"><div class="pr-rate-fill" style="width:${casePct}%;background:${r.color}"></div></div>
        <span class="pr-rate-num">~${r.perCase}</span>
      </div>
      <div class="pr-note">${r.note}</div>
    </div>`;
  }).join('');
}
function selectSet(slug){activeSet=slug;const s=SETS.find(x=>x.slug===slug);buildIndexRow();buildPillStrip();if(s){buildDetail(s);buildChart(s,activeTime);buildPerf(s);buildTopCards(s);buildSetTabs(slug);buildPullRates(s);}buildComparison();}
function setChartTime(el,period){document.querySelectorAll('.icc-right .icc-time').forEach(b=>b.classList.remove('on'));el.classList.add('on');activeTime=period;const s=SETS.find(x=>x.slug===activeSet);if(s)buildChart(s,period);}
