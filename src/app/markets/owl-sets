function buildTopCards(s){document.getElementById('top-cards-title').textContent=s.code;document.getElementById('top-cards-sub').textContent=`Top ${s.topCards.length} cards &middot; ${s.cards} total in ${s.code}`;document.getElementById('top-cards-tbody').innerHTML=s.topCards.map((c,i)=>`<tr><td class="rank-n">${i+1}</td><td><div class="card-cell"><div class="card-art">${c.e}</div><div style="min-width:0"><div class="card-name">${c.n}</div><div style="display:flex;align-items:center;gap:5px;margin-top:1px"><span class="card-set-tag">${s.code}</span></div></div></div></td><td><span class="rb ${c.rb}">${c.rl}</span></td><td class="price-r">$${c.avg.toFixed(2)}</td><td class="price-r">$${c.tcg}</td><td class="chg-r ${c.d1>=0?'up':'dn'}">${c.d1>=0?'+':''}${c.d1}%</td><td class="chg-r ${c.d7>=0?'up':'dn'}">${c.d7>=0?'+':''}${c.d7}%</td><td class="chg-r ${c.d30>=0?'up':'dn'}">${c.d30>=0?'+':''}${c.d30}%</td><td>${rowSpark(c.sp,c.d7>=0)}</td></tr>`).join('');}
function switchTopCards(slug){const s=SETS.find(x=>x.slug===slug);if(!s)return;buildSetTabs(slug);buildTopCards(s);}
function buildComparison(){document.getElementById('comp-grid').innerHTML=SETS.map(s=>`<div class="comp-card" onclick="selectSet('${s.slug}')" style="${activeSet===s.slug?'border-color:'+s.color+';box-shadow:0 0 0 1px '+s.color:''}"><div class="comp-top"><div class="comp-code-row"><span class="comp-code">${s.code}</span><span class="comp-badge" style="background:${s.colorD};color:${s.color};border:1px solid ${s.colorBd}">${s.year}</span></div><span class="comp-chg" style="color:${s.chg30d>=0?'var(--green)':'var(--red)'}">${s.chg30d>=0?'+':''}${s.chg30d}%</span></div><div class="comp-name">${s.name}</div><div class="comp-val">$${s.price.toLocaleString()}</div><div class="comp-meta">${s.cards} cards &middot; ${s.volume} vol</div><div class="comp-spark">${ricLineSparkFull(s.spark,s.color,s.up)}</div><div class="comp-footer"><div class="comp-stat">7D <span class="comp-stat-val" style="color:${s.up?'var(--green)':'var(--red)'}">${s.up?'+':''}${s.chg7d}%</span></div><div class="comp-stat">ATH <span class="comp-stat-val">${s.ath}</span></div><div class="comp-stat">Max <span class="comp-stat-val" style="color:var(--green)">+${s.chgMax}%</span></div></div></div>`).join('');}

