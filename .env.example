NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_legacy_service_role_key_that_starts_with_eyJ
ADMIN_EMAILS=you@example.com
JUSTTCG_API_KEY=your_justtcg_api_key
CRON_SECRET=your_vercel_cron_secret
RIOT_RIFTBOUND_API_KEY=
# Riot supplies the approved catalog endpoint/contract with app access.
RIOT_RIFTBOUND_CATALOG_URL=

# Multi-TCG rollout controls. Keep these values until the additive migrations
# have been applied and reconciled in staging.
MULTITCG_DUAL_WRITE_ENABLED=0
MULTITCG_READ_MODE=legacy

# JustTCG True Market is intentionally not normalized or written yet.

# Server-only. URL of the deployed Owl Lens CV service.
OWL_LENS_CV_URL=http://localhost:8000

# Optional. Absolute path to a local checkout of jwumanji/owl-lens.
# If set, sync reads contracts/openapi.yaml from here.
# Otherwise sync fetches the GitHub raw URL.
OWL_LENS_LOCAL_PATH=
