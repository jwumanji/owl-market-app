# ─────────────────────────────────────────────────────────────
# Owl Market – Local Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
#   cp .env.local.example .env.local
# `.env.local` is gitignored and must never be committed.
# After changing any variable, restart `npm run dev`.
# ─────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────
# Found in Supabase dashboard → Project Settings → API.
# The URL and anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key – SERVER ONLY. Bypasses RLS. Never expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── JustTCG API ─────────────────────────────────────────────
# Required for /api/sync/justtcg and price lookups.
# Get a key at https://justtcg.com
JUSTTCG_API_KEY=your-justtcg-api-key-here

# ── Sync / Cron secrets ─────────────────────────────────────
# Shared-secret tokens that gate the admin sync endpoints.
# Use any long random string locally (e.g. `openssl rand -hex 32`).
SYNC_SECRET=local-dev-sync-secret
CRON_SECRET=local-dev-cron-secret
